# ── Postgres ─────────────────────────────────────────────────────
RADAR_PG_DSN=postgresql://radar:radar@localhost:5432/radar
# For Supabase (use direct connection, not pooler, for prepared statements):
# RADAR_PG_DSN=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
# RADAR_PG_SSL=require

# ── Database API (centralized DB server) ─────────────────────────
# REQUIRED for validators/miners — URL of the centralized DB server
RADAR_DB_API_URL=http://<db-server-host>:8090
RADAR_DB_API_PORT=8090

# ── Validator Proxy ──────────────────────────────────────────────
RADAR_PROXY_PORT=8080
RADAR_PROXY_RATE_LIMIT=10

# ── LLM ──────────────────────────────────────────────────────────
# Provider: "openai" or "anthropic"
RADAR_LLM_PROVIDER=openai
RADAR_LLM_MODEL=gpt-4.1
RADAR_LLM_MODEL_STRONG=o3

# For Chutes or other OpenAI-compatible APIs:
# RADAR_LLM_BASE_URL=https://llm.chutes.ai/v1
# RADAR_LLM_API_KEY=your-chutes-key

# Or use standard env vars:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Execution ────────────────────────────────────────────────────
# "local" runs on this machine, "basilica" runs on Basilica cloud GPUs
RADAR_RUNNER_BACKEND=local
RADAR_TIME_BUDGET=300

# ── Round Timing ────────────────────────────────────────────────
# Two layers: BLOCK WINDOWS (phase boundaries, ~12s/block)
# and SECOND TIMEOUTS (operational limits within each phase).
# Seconds must fit inside their phase's block window.
#
# Block windows (all validators must agree):
# RADAR_SUBMISSION_WINDOW=50       # Phase A: 50 × 12s = 600s (~10 min)
# RADAR_TRAINING_WINDOW=150        # Phase B: 150 × 12s = 1800s (~30 min)
# RADAR_EVAL_WINDOW=25             # Phase C: 25 × 12s = 300s (~5 min)
# RADAR_ROUND_INTERVAL=275         # Total: 50+150+25+50 = 275 blocks (~55 min)
#
# Operational timeouts (seconds — must fit within block window):
# RADAR_AGENT_TIMEOUT=600          # Phase A: agent pod execution (≤ SUBMISSION_WINDOW × 12)
# RADAR_TIME_BUDGET=300            # Phase B: training compute budget (runner-enforced)
# (Phase C timeout is derived: EVAL_WINDOW × 12, no separate setting)

# ── GPU (local) ──────────────────────────────────────────────────
# No special config needed — just have CUDA installed.
# Your train.py controls device selection.

# ── GPU (Basilica cloud) ─────────────────────────────────────────
# RADAR_RUNNER_BACKEND=basilica
# RADAR_BASILICA_IMAGE=pytorch/pytorch:2.1.0-cuda12.1-cudnn8-runtime
# RADAR_BASILICA_GPU_COUNT=1
# RADAR_BASILICA_GPU_MODELS=A100,H100
# RADAR_BASILICA_MIN_GPU_MEMORY_GB=40
# RADAR_BASILICA_MEMORY=16Gi
# RADAR_BASILICA_CPU=4
# RADAR_BASILICA_PIP_PACKAGES=transformers,datasets,wandb
# RADAR_BASILICA_STORAGE=/data
# RADAR_BASILICA_ENV=HF_TOKEN,WANDB_API_KEY

# ── Data (for Basilica — forward tokens so containers can download data) ──
# HF_TOKEN=hf_...
# WANDB_API_KEY=...

# ── Evolution ────────────────────────────────────────────────────
RADAR_META_LEARNER=gepa
RADAR_MAX_PARETO=20
RADAR_MAX_EXPERIMENTS=0
RADAR_METRIC_PATTERN='val_bpb:\s*([\d.]+)'
RADAR_METRIC_LOWER_BETTER=true

# ── Task ─────────────────────────────────────────────────────────
RADAR_TASK=ml_training
RADAR_TARGET_FILE=train.py

# ── GitHub (optional, for pulling private images from GHCR) ──
# Generate at: https://github.com/settings/tokens (needs read:packages scope)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
# GITHUB_USER=tensorlink-dev
