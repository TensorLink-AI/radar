# Local stack env vars. None are required — the stack runs with no
# config at all using a deterministic stub LLM and a local SQLite file.

# LLM provider for /llm/chat and (when used) GEPA reflector.
# Chutes is checked first, OpenAI is the fallback, stub otherwise.
# CHUTES_API_KEY=cpk_...
# OPENAI_API_KEY=sk-...

# Override the prompts/active.json directory (default: prompts/ next
# to the agent dir).
# MINER_PROMPTS_DIR=/path/to/prompts

# ── GIFT-Eval / artifact storage (S3-compatible) ──
# Needed by `python -m local.fetch_gift_eval` and any code under
# shared/gift_eval.py + shared/r2_audit.py. Install the extras first:
#   pip install -e .[gift_eval]
#
# Primary: Hippius (S3-compatible, default endpoint https://s3.hippius.com)
# HIPPIUS_ACCESS_KEY_ID=hip_...
# HIPPIUS_SECRET_ACCESS_KEY=...
# HIPPIUS_BUCKET=gift-eval-benchmark
# HIPPIUS_ENDPOINT_URL=https://s3.hippius.com
#
# Legacy fallback: Cloudflare R2 (used only if no HIPPIUS_* vars are set)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=gift-eval-benchmark
#
# Local cache for downloaded Arrow files (default: /tmp/radar_gift_eval)
# RADAR_GIFT_EVAL_CACHE=/path/to/cache

# ── Pretrain bucket (separate from the eval bucket) ──
# Same S3 credentials as above, but a different bucket for pretrain shards.
# Loaded by `python -m local.fetch_pretrain` and by
# local/trainer.py when --task ts_forecasting is active.
# RADAR_PRETRAIN_BUCKET=gift-eval-pretrain
# Alternatives (in resolution order with RADAR_PRETRAIN_BUCKET first):
# HIPPIUS_PRETRAIN_BUCKET=gift-eval-pretrain
# R2_PRETRAIN_BUCKET=gift-eval-pretrain
#
# Local cache for downloaded parquet shards (default: /tmp/radar_pretrain)
# RADAR_PRETRAIN_CACHE=/path/to/cache

# ── Round-artifact mirror (S3/Hippius/R2) ──
# The artifact bucket is independent of the gift-eval / pretrain buckets
# so it can live in a different S3 account / provider. The validator
# mirrors each round here under `runs/{task}/r{round_id:06d}/...`:
#   challenge.json
#   miners/{miner_id}/proposal.json
#   miners/{miner_id}/submission.py
#   miners/{miner_id}/result.json
#   miners/{miner_id}/checkpoints/...   (ts_forecasting only)
#   miners/{miner_id}/logs/...
# When these are unset the validator falls back to HIPPIUS_*/R2_* above.
# Leave the access key blank to disable R2 mirroring entirely (SQLite-only).
# RADAR_ARTIFACT_BUCKET=radar-local
# RADAR_ARTIFACT_ACCESS_KEY_ID=...
# RADAR_ARTIFACT_SECRET_ACCESS_KEY=...
# RADAR_ARTIFACT_ENDPOINT_URL=https://s3.hippius.com
# R2-only: set account id and the endpoint is derived for you
#   (https://<account>.r2.cloudflarestorage.com), region defaults to auto.
# RADAR_ARTIFACT_ACCOUNT_ID=...
# RADAR_ARTIFACT_REGION=decentralized   # Hippius default; use 'auto' for R2
